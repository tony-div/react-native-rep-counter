{
  "$schema": "https://nitro.margelo.com/nitro.schema.json",
  "cxxNamespace": [
    "repcounter"
  ],
  "ios": {
    "iosModuleName": "NitroRepCounter"
  },
  "android": {
    "androidNamespace": [
      "repcounter"
    ],
    "androidCxxLibName": "NitroRepCounter"
  },
  "autolinking": {
    "RepCounter": {
      "all": {
        "language": "c++",
        "implementationClassName": "HybridRepCounter"
      }
    }
  },
  "ignorePaths": [
    "**/node_modules"
  ]
}
